{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm --prefix frontend-lovable install",
  "buildCommand": "npm --prefix frontend-lovable run build",
  "outputDirectory": "frontend-lovable/.output/public",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
